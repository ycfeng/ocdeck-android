# Copy this file to signing.properties for local release builds.
# Never commit signing.properties or keystore files.
# GitHub Actions uses the equivalent release Environment secrets documented in
# doc/release/github-actions.md; do not copy real values into repository files.
RELEASE_STORE_FILE=<absolute-path-outside-repository>
RELEASE_STORE_PASSWORD=<your-store-password>
RELEASE_KEY_ALIAS=<your-key-alias>
RELEASE_KEY_PASSWORD=<your-key-password>
