new file mode 100644
index 0000000..29afc5d
--- /dev/null
+++ b/client/runtime_state.go
@@ -0,0 +1,267 @@
+// Copyright 2026 The frp Authors
+//
+// Licensed under the Apache License, Version 2.0 (the "License");
+// you may not use this file except in compliance with the License.
+// You may obtain a copy of the License at
+//
+//     http://www.apache.org/licenses/LICENSE-2.0
+//
+// Unless required by applicable law or agreed to in writing, software
+// distributed under the License is distributed on an "AS IS" BASIS,
+// WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+// See the License for the specific language governing permissions and
+// limitations under the License.
+
+package client
+
+import (
+	"context"
+	"fmt"
+	"reflect"
+	"sync"
+
+	"github.com/fatedier/frp/client/visitor"
+	v1 "github.com/fatedier/frp/pkg/config/v1"
+)
+
+const (
+	SessionPhaseConnecting   = "connecting"
+	SessionPhaseOpen         = "open"
+	SessionPhaseReconnecting = "reconnecting"
+	SessionPhaseStopping     = "stopping"
+	SessionPhaseClosed       = "closed"
+	SessionPhaseFailed       = "failed"
+)
+
+type VisitorRuntimeState struct {
+	DesiredRevision   uint64
+	Phase             string
+	ListenerBound     bool
+	BoundControlEpoch uint64
+	LastError         string
+}
+
+type RuntimeState struct {
+	ConfigRevision uint64
+	ControlEpoch   uint64
+	Phase          string
+	LastError      string
+	Visitors       map[string]VisitorRuntimeState
+}
+
+type runtimeTracker struct {
+	mu      sync.Mutex
+	changed chan struct{}
+	state   RuntimeState
+}
+
+func newRuntimeTracker(initialVisitors []v1.VisitorConfigurer) *runtimeTracker {
+	tracker := &runtimeTracker{
+		changed: make(chan struct{}),
+		state: RuntimeState{
+			Phase:    SessionPhaseConnecting,
+			Visitors: make(map[string]VisitorRuntimeState),
+		},
+	}
+	if len(initialVisitors) > 0 {
+		tracker.state.ConfigRevision = 1
+		for _, cfg := range initialVisitors {
+			tracker.state.Visitors[cfg.GetBaseConfig().Name] = VisitorRuntimeState{
+				DesiredRevision: 1,
+				Phase:           visitor.PhasePending,
+			}
+		}
+	}
+	return tracker
+}
+
+func (svr *Service) runtimeTracker() *runtimeTracker {
+	svr.runtimeInitMu.Lock()
+	defer svr.runtimeInitMu.Unlock()
+	if svr.runtime == nil {
+		svr.runtime = newRuntimeTracker(nil)
+	}
+	return svr.runtime
+}
+
+func (r *runtimeTracker) notifyLocked() {
+	close(r.changed)
+	r.changed = make(chan struct{})
+}
+
+func (r *runtimeTracker) setPhase(phase string, lastError string) {
+	r.mu.Lock()
+	r.state.Phase = phase
+	r.state.LastError = lastError
+	r.notifyLocked()
+	r.mu.Unlock()
+}
+
+func (r *runtimeTracker) applyDesired(
+	oldVisitors []v1.VisitorConfigurer,
+	newVisitors []v1.VisitorConfigurer,
+) uint64 {
+	oldByName := make(map[string]v1.VisitorConfigurer, len(oldVisitors))
+	for _, cfg := range oldVisitors {
+		oldByName[cfg.GetBaseConfig().Name] = cfg
+	}
+
+	r.mu.Lock()
+	defer r.mu.Unlock()
+	r.state.ConfigRevision++
+	revision := r.state.ConfigRevision
+	next := make(map[string]VisitorRuntimeState, len(newVisitors))
+	for _, cfg := range newVisitors {
+		name := cfg.GetBaseConfig().Name
+		previousState, hasState := r.state.Visitors[name]
+		previousConfig, hasConfig := oldByName[name]
+		if hasState && hasConfig && reflect.DeepEqual(previousConfig, cfg) {
+			next[name] = previousState
+			continue
+		}
+		next[name] = VisitorRuntimeState{
+			DesiredRevision: revision,
+			Phase:           visitor.PhasePending,
+		}
+	}
+	r.state.Visitors = next
+	r.notifyLocked()
+	return revision
+}
+
+func (r *runtimeTracker) nextControlEpoch() uint64 {
+	r.mu.Lock()
+	defer r.mu.Unlock()
+	return r.state.ControlEpoch + 1
+}
+
+func (r *runtimeTracker) beginControl(epoch uint64) {
+	r.mu.Lock()
+	defer r.mu.Unlock()
+	if epoch <= r.state.ControlEpoch {
+		return
+	}
+	r.state.ControlEpoch = epoch
+	for name, state := range r.state.Visitors {
+		state.Phase = visitor.PhaseStarting
+		state.ListenerBound = false
+		state.BoundControlEpoch = 0
+		state.LastError = ""
+		r.state.Visitors[name] = state
+	}
+	r.notifyLocked()
+}
+
+func (r *runtimeTracker) markControlOpen(epoch uint64) {
+	r.mu.Lock()
+	defer r.mu.Unlock()
+	if r.state.ControlEpoch != epoch {
+		return
+	}
+	r.state.Phase = SessionPhaseOpen
+	r.state.LastError = ""
+	r.notifyLocked()
+}
+
+func (r *runtimeTracker) markControlDisconnected() {
+	r.mu.Lock()
+	defer r.mu.Unlock()
+	r.state.Phase = SessionPhaseReconnecting
+	for name, state := range r.state.Visitors {
+		state.Phase = visitor.PhasePending
+		state.ListenerBound = false
+		state.BoundControlEpoch = 0
+		r.state.Visitors[name] = state
+	}
+	r.notifyLocked()
+}
+
+func (r *runtimeTracker) reportVisitor(epoch uint64, name string, status visitor.RuntimeStatus) {
+	r.mu.Lock()
+	defer r.mu.Unlock()
+	if r.state.ControlEpoch != epoch {
+		return
+	}
+	state, ok := r.state.Visitors[name]
+	if !ok {
+		return
+	}
+	state.Phase = status.Phase
+	state.ListenerBound = status.ListenerBound
+	state.LastError = status.LastError
+	if status.ListenerBound {
+		state.BoundControlEpoch = epoch
+	} else {
+		state.BoundControlEpoch = 0
+	}
+	r.state.Visitors[name] = state
+	r.notifyLocked()
+}
+
+func (r *runtimeTracker) snapshot() RuntimeState {
+	r.mu.Lock()
+	defer r.mu.Unlock()
+	return cloneRuntimeState(r.state)
+}
+
+func (r *runtimeTracker) visitorState(name string) (VisitorRuntimeState, bool) {
+	r.mu.Lock()
+	defer r.mu.Unlock()
+	state, ok := r.state.Visitors[name]
+	return state, ok
+}
+
+func (r *runtimeTracker) waitVisitorReady(
+	ctx context.Context,
+	name string,
+	desiredRevision uint64,
+) (VisitorRuntimeState, error) {
+	for {
+		r.mu.Lock()
+		state := cloneRuntimeState(r.state)
+		changed := r.changed
+		r.mu.Unlock()
+
+		visitorState, ok := state.Visitors[name]
+		if !ok {
+			return VisitorRuntimeState{}, fmt.Errorf("visitor %q is not desired", name)
+		}
+		if visitorState.DesiredRevision > desiredRevision {
+			return visitorState, fmt.Errorf(
+				"visitor %q revision %d was superseded by revision %d",
+				name,
+				desiredRevision,
+				visitorState.DesiredRevision,
+			)
+		}
+		if visitorState.DesiredRevision == desiredRevision &&
+			visitorState.Phase == visitor.PhaseReady &&
+			visitorState.ListenerBound &&
+			visitorState.BoundControlEpoch == state.ControlEpoch &&
+			state.Phase == SessionPhaseOpen &&
+			state.ControlEpoch > 0 {
+			return visitorState, nil
+		}
+		if visitorState.DesiredRevision == desiredRevision &&
+			visitorState.Phase == visitor.PhaseFailed {
+			return visitorState, fmt.Errorf(
+				"visitor %q revision %d failed: %s",
+				name,
+				desiredRevision,
+				visitorState.LastError,
+			)
+		}
+		if state.Phase == SessionPhaseFailed || state.Phase == SessionPhaseClosed {
+			return visitorState, fmt.Errorf("frpc session is %s: %s", state.Phase, state.LastError)
+		}
+
+		select {
+		case <-ctx.Done():
+			if visitorState.LastError != "" {
+				return visitorState, fmt.Errorf(
+					"wait visitor %q revision %d: %w; last error: %s",
+					name,
+					desiredRevision,
+					ctx.Err(),
+					visitorState.LastError,
+				)
+			}
+			return visitorState, fmt.Errorf(
+				"wait visitor %q revision %d: %w",
+				name,
+				desiredRevision,
+				ctx.Err(),
+			)
+		case <-changed:
+		}
+	}
+}
+
+func cloneRuntimeState(state RuntimeState) RuntimeState {
+	clone := state
+	clone.Visitors = make(map[string]VisitorRuntimeState, len(state.Visitors))
+	for name, visitorState := range state.Visitors {
+		clone.Visitors[name] = visitorState
+	}
+	return clone
+}
+
+func (svr *Service) RuntimeState() RuntimeState {
+	return svr.runtimeTracker().snapshot()
+}
+
+func (svr *Service) GetVisitorRuntimeState(name string) (VisitorRuntimeState, bool) {
+	return svr.runtimeTracker().visitorState(name)
+}
+
+func (svr *Service) WaitVisitorReady(
+	ctx context.Context,
+	name string,
+	desiredRevision uint64,
+) (VisitorRuntimeState, error) {
+	return svr.runtimeTracker().waitVisitorReady(ctx, name, desiredRevision)
+}
+
+func (svr *Service) currentControl() *Control {
+	svr.ctlMu.RLock()
+	defer svr.ctlMu.RUnlock()
+	return svr.ctl
+}
+
+func (svr *Service) takeControlLocked() *Control {
+	svr.ctlMu.Lock()
+	defer svr.ctlMu.Unlock()
+	ctl := svr.ctl
+	svr.ctl = nil
+	return ctl
+}
+
+func (svr *Service) setControlLocked(ctl *Control) {
+	svr.ctlMu.Lock()
+	svr.ctl = ctl
+	svr.ctlMu.Unlock()
+}
+
+func (svr *Service) detachClosedControl(expected *Control) bool {
+	svr.reloadMu.Lock()
+	defer svr.reloadMu.Unlock()
+	svr.ctlMu.Lock()
+	defer svr.ctlMu.Unlock()
+	if svr.ctl != expected {
+		return false
+	}
+	svr.ctl = nil
+	return true
+}
diff --git a/client/runtime_state_test.go b/client/runtime_state_test.go
new file mode 100644
index 0000000..0000000
--- /dev/null
+++ b/client/runtime_state_test.go
@@ -0,0 +1,1 @@
+package client
+
+import (
+	"context"
+	"testing"
+	"time"
+
+	"github.com/fatedier/frp/client/visitor"
+	v1 "github.com/fatedier/frp/pkg/config/v1"
+)
+
+func TestWaitVisitorReadyRequiresOpenCurrentControl(t *testing.T) {
+	cfg := testRuntimeVisitorConfig("visitor", 4096)
+	tracker := newRuntimeTracker([]v1.VisitorConfigurer{cfg})
+	tracker.beginControl(1)
+	tracker.reportVisitor(1, "visitor", visitor.RuntimeStatus{
+		Phase:         visitor.PhaseReady,
+		ListenerBound: true,
+	})
+
+	ctx, cancel := context.WithTimeout(context.Background(), 20*time.Millisecond)
+	defer cancel()
+	if _, err := tracker.waitVisitorReady(ctx, "visitor", 1); err == nil {
+		t.Fatal("ready listener must not be published before the control is open")
+	}
+
+	tracker.markControlOpen(1)
+	state, err := tracker.waitVisitorReady(context.Background(), "visitor", 1)
+	if err != nil {
+		t.Fatalf("wait visitor ready: %v", err)
+	}
+	if !state.ListenerBound || state.BoundControlEpoch != 1 {
+		t.Fatalf("unexpected visitor state: %+v", state)
+	}
+}
+
+func TestWaitVisitorReadyRejectsStaleEpochAndSupersededRevision(t *testing.T) {
+	cfg := testRuntimeVisitorConfig("visitor", 4096)
+	tracker := newRuntimeTracker([]v1.VisitorConfigurer{cfg})
+	tracker.beginControl(1)
+	tracker.markControlOpen(1)
+	tracker.reportVisitor(1, "visitor", visitor.RuntimeStatus{
+		Phase:         visitor.PhaseReady,
+		ListenerBound: true,
+	})
+	tracker.markControlDisconnected()
+
+	ctx, cancel := context.WithTimeout(context.Background(), 20*time.Millisecond)
+	defer cancel()
+	if _, err := tracker.waitVisitorReady(ctx, "visitor", 1); err == nil {
+		t.Fatal("stale control epoch must not remain ready")
+	}
+
+	updated := testRuntimeVisitorConfig("visitor", 4097)
+	revision := tracker.applyDesired([]v1.VisitorConfigurer{cfg}, []v1.VisitorConfigurer{updated})
+	if revision <= 1 {
+		t.Fatalf("expected a newer revision, got %d", revision)
+	}
+	if _, err := tracker.waitVisitorReady(context.Background(), "visitor", 1); err == nil {
+		t.Fatal("superseded revision must fail")
+	}
+}
+
+func TestWaitVisitorReadyReturnsBindFailure(t *testing.T) {
+	cfg := testRuntimeVisitorConfig("visitor", 4096)
+	tracker := newRuntimeTracker([]v1.VisitorConfigurer{cfg})
+	tracker.beginControl(1)
+	tracker.markControlOpen(1)
+	tracker.reportVisitor(1, "visitor", visitor.RuntimeStatus{
+		Phase:     visitor.PhaseFailed,
+		LastError: "bind failed",
+	})
+
+	if _, err := tracker.waitVisitorReady(context.Background(), "visitor", 1); err == nil {
+		t.Fatal("visitor bind failure must be returned without waiting for timeout")
+	}
+}
+
+func testRuntimeVisitorConfig(name string, bindPort int) *v1.STCPVisitorConfig {
+	return &v1.STCPVisitorConfig{
+		VisitorBaseConfig: v1.VisitorBaseConfig{
+			Name:       name,
+			Type:       string(v1.VisitorTypeSTCP),
+			ServerName: "server",
+			SecretKey:  "test-secret",
+			BindAddr:   "127.0.0.1",
+			BindPort:   bindPort,
+		},
+	}
+}
diff --git a/client/visitor/visitor_manager_runtime_test.go b/client/visitor/visitor_manager_runtime_test.go
new file mode 100644
index 0000000..0000000
--- /dev/null
+++ b/client/visitor/visitor_manager_runtime_test.go
@@ -0,0 +1,1 @@
+package visitor
+
+import (
+	"errors"
+	"net"
+	"strconv"
+	"testing"
+
+	v1 "github.com/fatedier/frp/pkg/config/v1"
+	"github.com/fatedier/frp/pkg/msg"
+)
+
+func TestManagerReportsReadyOnlyAfterListenerBindAndCloseReleasesPort(t *testing.T) {
+	port := reservePort(t)
+	var statuses []RuntimeStatus
+	manager := NewManager(
+		t.Context(),
+		"run-id",
+		&v1.ClientCommonConfig{},
+		func() (*msg.Conn, error) { return nil, errors.New("unused") },
+		nil,
+		nil,
+		func(_ string, status RuntimeStatus) { statuses = append(statuses, status) },
+	)
+
+	if err := manager.UpdateAll([]v1.VisitorConfigurer{testSTCPConfig("visitor", port)}); err != nil {
+		t.Fatalf("start visitor: %v", err)
+	}
+	last := statuses[len(statuses)-1]
+	if last.Phase != PhaseReady || !last.ListenerBound {
+		t.Fatalf("unexpected last status: %+v", last)
+	}
+	if listener, err := net.Listen("tcp", net.JoinHostPort("127.0.0.1", strconv.Itoa(port))); err == nil {
+		listener.Close()
+		t.Fatal("visitor ready was reported without retaining the listener")
+	}
+
+	manager.Close()
+	listener, err := net.Listen("tcp", net.JoinHostPort("127.0.0.1", strconv.Itoa(port)))
+	if err != nil {
+		t.Fatalf("listener was not released by Close: %v", err)
+	}
+	listener.Close()
+	if err := manager.UpdateAll([]v1.VisitorConfigurer{testSTCPConfig("visitor", port)}); !errors.Is(err, ErrManagerClosed) {
+		t.Fatalf("closed manager accepted an update: %v", err)
+	}
+}
+
+func TestManagerReportsBindFailure(t *testing.T) {
+	listener, err := net.Listen("tcp", "127.0.0.1:0")
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer listener.Close()
+	port := listener.Addr().(*net.TCPAddr).Port
+
+	var statuses []RuntimeStatus
+	manager := NewManager(
+		t.Context(),
+		"run-id",
+		&v1.ClientCommonConfig{},
+		func() (*msg.Conn, error) { return nil, errors.New("unused") },
+		nil,
+		nil,
+		func(_ string, status RuntimeStatus) { statuses = append(statuses, status) },
+	)
+	defer manager.Close()
+
+	if err := manager.UpdateAll([]v1.VisitorConfigurer{testSTCPConfig("visitor", port)}); err == nil {
+		t.Fatal("expected bind failure")
+	}
+	last := statuses[len(statuses)-1]
+	if last.Phase != PhaseFailed || last.ListenerBound || last.LastError == "" {
+		t.Fatalf("unexpected failure status: %+v", last)
+	}
+}
+
+func reservePort(t *testing.T) int {
+	t.Helper()
+	listener, err := net.Listen("tcp", "127.0.0.1:0")
+	if err != nil {
+		t.Fatal(err)
+	}
+	port := listener.Addr().(*net.TCPAddr).Port
+	listener.Close()
+	return port
+}
+
+func testSTCPConfig(name string, bindPort int) *v1.STCPVisitorConfig {
+	return &v1.STCPVisitorConfig{
+		VisitorBaseConfig: v1.VisitorBaseConfig{
+			Name:       name,
+			Type:       string(v1.VisitorTypeSTCP),
+			ServerName: "server",
+			SecretKey:  "test-secret",
+			BindAddr:   "127.0.0.1",
+			BindPort:   bindPort,
+		},
+	}
+}
